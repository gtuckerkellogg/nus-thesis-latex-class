  \keys_define:nn { nus-thesis } {
    , font / #1 .code:n = {
        \bool_if:NF \g__nusthesis_fonttheme_loaded_bool {
          \__nusthesis_load_fonttheme:n { #1 }
          \bool_gset_true:N \g__nusthesis_fonttheme_loaded_bool
        }
      }
  }
}

