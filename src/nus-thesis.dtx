% \section{Introduction}
%
% The \textsf{nus-thesis} class typesets theses and dissertations conforming
% to the submission requirements of the National University of Singapore.
% It is built on top of the standard \textsf{book} class and uses
% \LaTeX3 (\textsf{expl3}) internally.  A document formatted using this class will be compatible with the
% guidelines issued by the NUS Graduate School as of NUSGS.073/22 (1 April 2026).
%
% The class sets A4 paper, 12\,pt font size, one-sided layout, and double
% line spacing by default.  Page margins follow NUS requirements:
% 1.5\,in left and right, 1\,in top and bottom.
%
% \subsection{Quick Start}
%
% A minimal working document:
%
% \begin{verbatim}
% \documentclass{nus-thesis}
% \ThesisSetup{
%   author          = Jane Smith,
%   title           = My Dissertation,
%   candidacy       = Doctor of Philosophy,
%   department      = Department of Biological Sciences,
%   field           = Biology,
%   submission-year = 2025,
% }
% \begin{document}
% \maketitle
% \begin{declaration}
%   \DeclarationStatement
%   \DeclarationGenAI
%   \DeclarationSignature
% \end{declaration}
% \begin{acknowledgements}
%   I thank \ldots
% \end{acknowledgements}
% \begin{abstract}
%   This thesis investigates \ldots
% \end{abstract}
% \tableofcontents
% \mainmatter
% \chapter{Introduction}
% \ldots
% \end{document}
% \end{verbatim}
%
% \section{Class Options}
%
% Class options can be passed via \cs{documentclass} or as keys in
% \cs{ThesisSetup}.  Unknown options are forwarded to the underlying
% \textsf{book} class.
%
% \begin{function}{oneside}
%   \begin{syntax}
%     |oneside| = \meta{true,false}
%   \end{syntax}
% Format as one-sided so that there is no distinction between left and right
% hand pages.  Defaults to \texttt{true}.
% \end{function}
%
% \begin{function}{openright}
%   \begin{syntax}
%     |openright| = \meta{true,false}
%   \end{syntax}
% Ensure that new chapters open on the right-hand side.  Defaults to
% \texttt{true} because good typesetting usually sets chapters in a printed book to begin on the right-hand side.
% Some examiners may not appreciate good typesetting and may complain about blank pages. Set this option to \texttt{false}
% to address or anticipate this complaint.
% \end{function}
%
% \section{Thesis Configuration}
%
% All thesis metadata and behaviour is controlled through
% \cs{ThesisSetup}\marg{key=value, \ldots}, which may be called once or
% multiple times in the document preamble.
%
% \begin{function}{\ThesisSetup}
%   \begin{syntax}
%     |\ThesisSetup|\marg{key=value, \ldots}
%   \end{syntax}
% The main configuration command.  All keys described in this section are
% accepted.
% \end{function}
%
% \subsection{Author and Title}
%
% \begin{function}{author}
%   \begin{syntax}
%     |author| = \meta{name}
%   \end{syntax}
% The full name of the author.  Required; appears on the cover page, title
% page, declaration, and signature block.
% \end{function}
%
% \begin{function}{title}
%   \begin{syntax}
%     |title| = \meta{title text}
%   \end{syntax}
% The title of the thesis.  Required; displayed in uppercase on the cover and
% title pages.
% \end{function}
%
% \subsection{Institutional Details}
%
% \begin{function}{university}
%   \begin{syntax}
%     |university| = \meta{name}
%   \end{syntax}
% University name.  Defaults to \textit{National University of Singapore}.
% \end{function}
%
% \begin{function}{department}
%   \begin{syntax}
%     |department| = \meta{name}
%   \end{syntax}
% Department or faculty name, as it should appear on the title page.
% \end{function}
%
% \begin{function}{field}
%   \begin{syntax}
%     |field| = \meta{field}
%   \end{syntax}
% The field or discipline of the thesis.
% \end{function}
%
% \subsection{Document Classification}
%
% \begin{function}{document-type}
%   \begin{syntax}
%     |document-type| = \meta{type}
%   \end{syntax}
% The type of document, used throughout the declaration text.  Common values
% are |thesis| (default) and |report|.
% \end{function}
%
% \begin{function}{candidacy}
%   \begin{syntax}
%     |candidacy| = \meta{degree}
%   \end{syntax}
% The degree being sought, e.g.\ |Doctor of Philosophy| or
% |Master of Science|.  Appears on the title page.
% \end{function}
%
% \begin{function}{qualification}
%   \begin{syntax}
%     |qualification| = \meta{text}
%   \end{syntax}
% Prior qualifications of the author, shown in parentheses below the author
% name on the title page, e.g.\ |B.Sc.\ (Hons.), University of X|.
% \end{function}
%
% \subsection{Submission Details}
%
% \begin{function}{submission-year}
%   \begin{syntax}
%     |submission-year| = \meta{year}
%   \end{syntax}
% The four-digit submission year.  Defaults to the current year.
% \end{function}
%
% \begin{function}{advisor}
%   \begin{syntax}
%     |advisor| = \meta{name(s)}
%   \end{syntax}
% Supervisor name(s).  Printed on the title page only when |final = true|.
% \end{function}
%
% \begin{function}{examiners}
%   \begin{syntax}
%     |examiners| = \meta{name(s)}
%   \end{syntax}
% Examiner name(s).  Printed on the title page only when |final = true|.
% \end{function}
%
% \subsection{Submission Mode}
%
% \begin{function}{strict}
%   \begin{syntax}
%     |strict| = \meta{true,false}
%   \end{syntax}
% When |true|, enforces old-school NUS compliance: plain chapter heading style
% (no decorative large chapter number) \emph{and} the Times font theme.
% The Times font is forced even if a different |font| key was set earlier.
% Defaults to |false|.
% \end{function}
%
% \begin{function}{final}
%   \begin{syntax}
%     |final| = \meta{true,false}
%   \end{syntax}
% When |true|, adds the advisor and examiner names to the title page.
% Intended for the final hard-bound submission copy.  Defaults to |false|.
% \end{function}
%
% \section{Font Themes}
%
% The |font| key selects a pre-configured font theme that controls body
% text, headings, captions, and mathematics throughout the document.
% Each theme works with pdf\/TeX, \XeTeX, and Lua\TeX, automatically
% selecting appropriate fonts for the current engine.
%
% The current NUS Guidelines on Format of Research Thesis do not require any
% specific font. The guidelines instead provide recommendations: ``Fonts should be
% clear and easy to read. Acceptable fonts include Times New Roman and Helvetica.''
% The built-in font themes listed below include both a Times-based theme and a Helvetica-based
% theme. along with other themes based on the class author's strongly held beliefs
% about good typography. In each case, mathematical fonts are chosen to complement the main font.
%
% \subsection{Built-in Themes}
%
% \begin{function}{computermodern}
%   \begin{syntax}
%     |font| = |computermodern|
%   \end{syntax}
% Classic Computer Modern typography (Knuth's original design), using Latin
% Modern for improved quality and Unicode support.
% Math fonts: Computer Modern Math (pdf\/TeX) or Latin Modern Math
% (\XeTeX/Lua\TeX).
% \end{function}
%
% \begin{function}{times}
%   \begin{syntax}
%     |font| = |times|
%   \end{syntax}
% Classic Times Roman serif for all document elements.
% Math fonts: \textsf{mathptmx} (pdf\/TeX) or TeX Gyre Termes Math
% (\XeTeX/Lua\TeX).
% \end{function}
%
% \begin{function}{helvetica}
%   \begin{syntax}
%     |font| = |helvetica|
%   \end{syntax}
% Modern sans-serif theme using Helvetica throughout, including mathematics.
% Math fonts: \textsf{arevmath} (pdf\/TeX) or Fira Math (\XeTeX/Lua\TeX).
% \end{function}
%
% \begin{function}{palatino}
%   \begin{syntax}
%     |font| = |palatino|
%   \end{syntax}
% Palatino serif for body text with Helvetica for headings. Palatino is an 
% Math fonts: \textsf{mathpazo} (pdf\/TeX) or TeX Gyre Pagella Math
% (\XeTeX/Lua\TeX).
% \end{function}
%
% \begin{function}{libertine}
%   \begin{syntax}
%     |font| = |libertine|
%   \end{syntax}
% Linux Libertine serif with sans-serif headings.  Excellent Unicode coverage.
% Math fonts: \textsf{libertinust1math} (pdf\/TeX) or Libertinus Math
% (\XeTeX/Lua\TeX).
% \end{function}
%
% \begin{function}{noto}
%   \begin{syntax}
%     |font| = |noto|
%   \end{syntax}
% Google Noto fonts with comprehensive language support.
% Math fonts: \textsf{notomath} (pdf\/TeX) or STIX Two Math (\XeTeX/Lua\TeX).
% \end{function}
%
% \begin{function}{minionpro}
%   \begin{syntax}
%     |font| = |minionpro|
%   \end{syntax}
% Adobe Minion Pro serif with Myriad Pro sans (requires commercial fonts).
% Math fonts: \textsf{MinionPro} (pdf\/TeX) or TeX Gyre Pagella Math
% (\XeTeX/Lua\TeX).
% \end{function}
%
% \subsection{Defining Custom Themes}
% 
% Class users may not be satisfied with the available themes, and may define custom themes
% for different font classes. Because Xe\LaTeX{} and Lua\LaTeX{} can access system fonts,
% a simplified theme definition is sufficient for these engines.
%
% \begin{function}{\ThesisDefineFontTheme}
%   \begin{syntax}
%     |\ThesisDefineFontTheme|\marg{name}\marg{options}
%   \end{syntax}
% User-friendly command for defining custom font themes using OpenType font
% names.  Works with Xe\LaTeX{} and Lua\LaTeX{} via \textsf{fontspec}.
%
% Available options: |main-font|, |sans-font|, |mono-font|, |math-font|,
% |chaphead-style|, |heading-style|, |titlepage-style|, |caption-style|.
% Style values are |serif|, |sans|, or |mono|.
%
% \begin{verbatim}
% \ThesisDefineFontTheme{mytheme}{
%   main-font = {Palatino},
%   sans-font = {Helvetica},
%   mono-font = {Inconsolata},
%   math-font = {TeX Gyre Pagella Math},
%   heading-style = sans,
% }
% \ThesisSetup{font = mytheme}
% \end{verbatim}
% \end{function}
%
% \begin{function}{\DeclareThesisFontTheme}
%   \begin{syntax}
%     |\DeclareThesisFontTheme|\marg{name}\marg{config}
%   \end{syntax}
% Advanced command for defining themes that work on all \TeX\ engines.
% Allows explicit configuration for pdf\/TeX, \XeTeX, and Lua\TeX.
%
% Configuration keys: |pdftex|, |xetex|, |luatex|, |fontspec|,
% |hooks/body|, |hooks/titlepage|, |hooks/chaphead|, |hooks/heading|,
% |hooks/caption|, |hooks/verbatim|, |hooks/math|.
%
% \begin{verbatim}
% \DeclareThesisFontTheme{advanced}{
%   pdftex = {
%     \RequirePackage[sc]{mathpazo}
%     \RequirePackage[scaled=0.95]{helvet}
%   },
%   fontspec = {
%     \RequirePackage{unicode-math}
%     \setmainfont{TeX Gyre Pagella}
%     \setmathfont{TeX Gyre Pagella Math}
%   },
%   hooks/chaphead = \sffamily,
% }
% \end{verbatim}
% \end{function}
%
% \section{Optional Features}
%
% \subsection{Glossaries and Acronyms}
%
% \begin{function}{glossaries}
%   \begin{syntax}
%     |glossaries| = \meta{true,false}
%   \end{syntax}
% Controls whether the \textsf{glossaries-extra} package is loaded.
% Defaults to |false| to avoid warnings when glossaries are not needed.
%
% When |true|, loads \textsf{glossaries-extra} with abbreviation support,
% enabling |\newacronym|, |\gls|, and |\printglossary|.
%
% \begin{verbatim}
% \ThesisSetup{glossaries = true}
% \newacronym{api}{API}{Application Programming Interface}
% First use: \gls{api}. Second use: \gls{api}.
% \printglossary[type=abbreviations]
% \end{verbatim}
% \end{function}
%
% \section{Document Structure}
%
% A typical NUS thesis follows this structure:
%
% \begin{verbatim}
% \documentclass{nus-thesis}
% \ThesisSetup{ ... }
% \begin{document}
%   \maketitle                % cover page + title page
%   \begin{declaration}...\end{declaration}
%   \begin{acknowledgements}...\end{acknowledgements}
%   \begin{abstract}...\end{abstract}
%   \tableofcontents
%   \listoftables             % if needed
%   \listoffigures            % if needed
%   \mainmatter
%   \chapter{Introduction}
%   ...
%   \appendix
%   \bibliographystyle{...}
%   \bibliography{refs}
% \end{document}
% \end{verbatim}
%
% \cs{maketitle} calls \cs{frontmatter} internally, so you do not need to
% issue \cs{frontmatter} yourself.  Call \cs{mainmatter} before your first
% numbered chapter.
%
% \section{Front Matter}
%
% \subsection{Cover and Title Pages}
%
% \begin{function}{\maketitle}
%   \begin{syntax}
%     |\maketitle|
%   \end{syntax}
% Generates a cover page followed by a title page, and calls
% \cs{frontmatter} automatically.  It should be the first command inside
% \cs{document}.
%
% The cover page shows the title, author, university, and year.
% The title page adds the degree candidacy and department, and when
% |final = true| also the advisor and examiner names.
% \end{function}
%
% \subsection{Declaration Page}
%
% NUS requires all theses to include a signed declaration of originality.
% The class provides a composable environment supporting the mandatory
% originality statement, an optional generative-AI disclosure, and a
% signature block.
%
% \begin{environment}{declaration}
%   \begin{syntax}
%     |\begin{declaration}|
%     \quad|\DeclarationStatement|
%     \quad|\DeclarationGenAI| \oarg{none}
%     \quad|\DeclarationSignature| \oarg{image}
%     |\end{declaration}|
%   \end{syntax}
% Opens a self-contained declaration page.  A typical usage when AI tools
% were used:
% \begin{verbatim}
% \begin{declaration}
%   \DeclarationStatement
%   \DeclarationGenAI           % template B: AI used
%   \DeclarationSignature       % add [sig.png] for a signature image
% \end{declaration}
% \end{verbatim}
% \end{environment}
%
% \begin{function}{\DeclarationStatement}
%   \begin{syntax}
%     |\DeclarationStatement|
%   \end{syntax}
% Typesets the mandatory NUS originality statement.  The word
% \meta{document-type} tracks the |document-type| key.
% \end{function}
%
% \begin{function}{\DeclarationGenAI}
%   \begin{syntax}
%     |\DeclarationGenAI|
%     |\DeclarationGenAI| \oarg{none}
%   \end{syntax}
% Typesets a \textbf{Use of Generative AI} disclosure.  Without an argument,
% emits Template~B (AI used for language refinement and proofreading).
% With |[none]|, emits Template~A (no AI tools used).
%
% \begin{verbatim}
% \DeclarationGenAI           % template B: AI used
% \DeclarationGenAI[none]     % template A: no AI used
% \end{verbatim}
%
% For situations not covered by either template, use
% \cs{DeclarationGenAICustom}.
% \end{function}
%
% \begin{function}{\DeclarationGenAICustom}
%   \begin{syntax}
%     |\DeclarationGenAICustom|\marg{text}
%   \end{syntax}
% Typesets a \textbf{Use of Generative AI} heading followed by arbitrary
% \meta{text}.
% \begin{verbatim}
% \DeclarationGenAICustom{I used LLM tools to generate initial outlines
%   for Chapters~3 and~5, which I subsequently rewrote entirely.}
% \end{verbatim}
% \end{function}
%
% \begin{function}{\DeclarationSignature}
%   \begin{syntax}
%     |\DeclarationSignature|
%     |\DeclarationSignature| \oarg{image}
%   \end{syntax}
% Typesets a centred signature block with the author name and date.
% When the optional \meta{image} path is supplied, the image is placed
% above the signature line.
%
% \begin{verbatim}
% \DeclarationSignature                    % unsigned
% \DeclarationSignature[./signature.png]   % with image
% \end{verbatim}
% \end{function}
%
% \begin{function}{\DeclarationPage}
%   \begin{syntax}
%     |\DeclarationPage|
%     |\DeclarationPage| \oarg{image}
%   \end{syntax}
% A backward-compatible shorthand that emits a |declaration| environment
% containing only \cs{DeclarationStatement} and \cs{DeclarationSignature}
% (no AI disclosure).  New documents should prefer the full environment.
% \end{function}
%
% \subsection{Acknowledgements}
%
% \begin{environment}{acknowledgements}
%   \begin{syntax}
%     |\begin{acknowledgements}|
%     \meta{text}
%     |\end{acknowledgements}|
%   \end{syntax}
% Typesets an unnumbered chapter titled ``Acknowledgements'' and adds an
% entry to the table of contents.
% \begin{verbatim}
% \begin{acknowledgements}
%   I thank my supervisor for their guidance \ldots
% \end{acknowledgements}
% \end{verbatim}
% \end{environment}
%
% \subsection{Abstract}
%
% \begin{environment}{abstract}
%   \begin{syntax}
%     |\begin{abstract}| \oarg{prefix}
%     \meta{abstract text}
%     |\end{abstract}|
%   \end{syntax}
% Typesets an unnumbered chapter and adds it to the table of contents.
% Without a \meta{prefix} the chapter is titled ``Abstract''; with a prefix
% such as |[Lay]| it is titled ``Lay Abstract''.
%
% \begin{verbatim}
% \begin{abstract}
%   This thesis investigates \dots
% \end{abstract}
%
% \begin{abstract}[Lay]
%   In plain language, this thesis is about \dots
% \end{abstract}
% \end{verbatim}
% \end{environment}
%
% \subsection{Lists of Tables and Figures}
%
% Use the standard \cs{listoftables} and \cs{listoffigures} commands.
% Both are redefined to use single spacing internally and to add a table of
% contents entry.  The class automatically inserts a chapter-level heading
% into these lists whenever a float first appears in a new chapter.
%
% \section{Main Matter}
%
% \subsection{Chapter Headings}
%
% By default, chapters display a large decorative chapter number in grey.
% Setting |strict = true| in \cs{ThesisSetup} reverts to a plain heading.
%
% \subsection{Floats and Captions}
%
% Table and figure captions are styled in small sans-serif with a bold label
% and period separator.
%
% \begin{function}{\ResetFloatsInChapter}
%   \begin{syntax}
%     |\ResetFloatsInChapter|
%   \end{syntax}
% Resets the internal tracking that inserts chapter headings into the list
% of tables and list of figures.  Called automatically at the start of each
% chapter; exposed here for use in exceptional circumstances.
% \end{function}
%
% \section{Back Matter}
%
% \subsection{Appendices}
%
% Use the standard |\appendix| command (or the |appendices| environment from
% the \textsf{appendix} package, which is loaded by the class).
% Chapter headings in the appendix section are reformatted as
% \textit{Appendix~A}, \textit{Appendix~B}, etc., and an ``Appendices''
% part entry is added to the table of contents.
%
% \begin{verbatim}
% \appendix
% \chapter{Supplementary Data}
% \end{verbatim}
%
% \subsection{List of Symbols and Abbreviations}
%
% \begin{function}{\listofsymbolsnabbrev}
%   \begin{syntax}
%     |\listofsymbolsnabbrev|
%   \end{syntax}
% Typesets a list of symbols followed by a list of abbreviations.  Entries
% are added with \cs{addsymbol} and \cs{addabbrev} throughout the document.
% \end{function}
%
% \begin{function}{\addsymbol}
%   \begin{syntax}
%     |\addsymbol|\marg{symbol}\marg{description}
%   \end{syntax}
% Adds an entry to the list of symbols.
% \begin{verbatim}
% \addsymbol{$\alpha$}{Significance level}
% \addsymbol{$\mu$}{Population mean}
% \end{verbatim}
% \end{function}
%
% \begin{function}{\addabbrev}
%   \begin{syntax}
%     |\addabbrev|\marg{abbreviation}\marg{expansion}
%   \end{syntax}
% Adds an entry to the list of abbreviations.
% \begin{verbatim}
% \addabbrev{DNA}{Deoxyribonucleic Acid}
% \addabbrev{PCR}{Polymerase Chain Reaction}
% \end{verbatim}
% \end{function}
%
% \StopEventually{}
%
% \section{Implementation}
%
% This section documents the internal implementation of the
% \textsf{nus-thesis} class.  It is intended for class maintainers.
%
% \subsection{Base Class Setup}
%
% Load \textsf{book} with NUS-required defaults, then handle engine-specific
% font encoding.
%
%    \begin{macrocode}
%<*class>
\str_const:Nn \c__classname_base_class_str { book }

\PassOptionsToClass{a4paper}{\c__classname_base_class_str}
\PassOptionsToClass{12pt}{\c__classname_base_class_str}
\PassOptionsToClass{oneside}{\c__classname_base_class_str}
\PassOptionsToClass{openright}{\c__classname_base_class_str}
\LoadClass { \c__classname_base_class_str }

\sys_if_engine_pdftex:TF {
  \RequirePackage[T1]{fontenc}
  \RequirePackage[utf8]{inputenc}
  \RequirePackage{textcomp}
  } {
    \RequirePackage{fontspec}
    \sys_if_engine_xetex:T { \RequirePackage{xunicode} }
}
%    \end{macrocode}
%
% \subsection{Font Theme System}
%
% Font hooks allow themes to override font families in specific contexts.
% Each hook is a zero-argument command that switches font family; the
% defaults use \cs{normalfont}.
%
%    \begin{macrocode}
\cs_new:Npn \__nusthesis_body_font: { \normalfont }
\cs_new:Npn \__nusthesis_titlepage_font: { \normalfont }
\cs_new:Npn \__nusthesis_chaphead_font: { \normalfont }
\cs_new:Npn \__nusthesis_heading_font: { \normalfont }
\cs_new:Npn \__nusthesis_caption_font: { \normalfont }
\cs_new:Npn \__nusthesis_verbatim_font: { \ttfamily }
\cs_new:Npn \__nusthesis_math_setup: { }

\bool_new:N \l__thesis_use_glossaries_bool

\prop_new:N \g__nusthesis_fontthemes_prop

\str_new:N \l__nusthesis_engine_str
\sys_if_engine_pdftex:TF {
  \str_set:Nn \l__nusthesis_engine_str { pdftex }
} {
