%
% \section{Font Themes}
%
% The |font| key allows selection of pre-configured font themes that control the appearance of
% text, headings, captions, and mathematical expressions throughout the document. Each theme works
% with pdfTeX, XeTeX, and LuaTeX, automatically selecting appropriate fonts for the engine.
%
% \subsection{Built-in Themes}
%
% \begin{function}{computermodern}
%   \begin{syntax}
%     |font| = |computermodern|
%   \end{syntax}
% Classic Computer Modern typography (Knuth's original TeX design).
% Uses Latin Modern fonts for improved quality and Unicode support.
% Math fonts: Computer Modern Math (pdfTeX) or Latin Modern Math (XeTeX/LuaTeX).
% \end{function}
%
% \begin{function}{times}
%   \begin{syntax}
%     |font| = |times|
%   \end{syntax}
% Classic Times Roman serif font for all document elements.
% Math fonts: mathptmx (pdfTeX) or TeX Gyre Termes Math (XeTeX/LuaTeX).
% \end{function}
%
% \begin{function}{helvetica}
%   \begin{syntax}
%     |font| = |helvetica|
%   \end{syntax}
% Modern sans-serif theme using Helvetica throughout, including mathematical expressions.
% Math fonts: arevmath (pdfTeX) or Fira Math (XeTeX/LuaTeX).
% \end{function}
%
% \begin{function}{palatino}
%   \begin{syntax}
%     |font| = |palatino|
%   \end{syntax}
% Palatino serif for body text with Helvetica for headings. Professional combination.
% Math fonts: mathpazo (pdfTeX) or TeX Gyre Pagella Math (XeTeX/LuaTeX).
% \end{function}
%
% \begin{function}{libertine}
%   \begin{syntax}
%     |font| = |libertine|
%   \end{syntax}
% Linux Libertine serif with sans-serif headings. Excellent Unicode coverage.
% Math fonts: libertinust1math (pdfTeX) or Libertinus Math (XeTeX/LuaTeX).
% \end{function}
%
% \begin{function}{noto}
%   \begin{syntax}
%     |font| = |noto|
%   \end{syntax}
% Google Noto fonts with comprehensive language support.
% Math fonts: notomath (pdfTeX) or Latin Modern Math (XeTeX/LuaTeX).
% \end{function}
%
% \begin{function}{minionpro}
%   \begin{syntax}
%     |font| = |minionpro|
%   \end{syntax}
% Adobe Minion Pro serif with Myriad Pro sans (requires commercial fonts).
% Math fonts: MinionPro (pdfTeX) or TeX Gyre Pagella Math (XeTeX/LuaTeX).
% \end{function}
%
% \subsection{Defining Custom Themes}
%
% \begin{function}{\ThesisDefineFontTheme}
%   \begin{syntax}
%     |\ThesisDefineFontTheme|\marg{name}\marg{options}
%   \end{syntax}
% User-friendly command for defining custom font themes using OpenType fonts. Works with XeTeX
% and LuaTeX via fontspec.
%
% Available options: |main-font|, |sans-font|, |mono-font|, |math-font|,
% |chaphead-style|, |heading-style|, |titlepage-style|, |caption-style|
%
% Style values: |serif|, |sans|, or |mono|
%
% Example:
% \begin{verbatim}
% \ThesisDefineFontTheme{mytheme}{
%   main-font = {Palatino},
%   sans-font = {Helvetica},
%   mono-font = {Inconsolata},
%   math-font = {TeX Gyre Pagella Math},
%   heading-style = sans,
% }
% \ThesisSetup{font = mytheme}
% \end{verbatim}
% \end{function}
%
% \begin{function}{\DeclareThesisFontTheme}
%   \begin{syntax}
%     |\DeclareThesisFontTheme|\marg{name}\marg{config}
%   \end{syntax}
% Advanced command for defining themes that work on all TeX engines. Allows explicit configuration
% for pdfTeX, XeTeX, and LuaTeX.
%
% Configuration keys: |pdftex|, |xetex|, |luatex|, |fontspec|,
% |hooks/body|, |hooks/titlepage|, |hooks/chaphead|, |hooks/heading|,
% |hooks/caption|, |hooks/verbatim|, |hooks/math|
%
% Example:
% \begin{verbatim}
% \DeclareThesisFontTheme{advanced}{
%   pdftex = {
%     \RequirePackage[sc]{mathpazo}
%     \RequirePackage[scaled=0.95]{helvet}
%   },
%   fontspec = {
%     \RequirePackage{unicode-math}
%     \setmainfont{TeX Gyre Pagella}
%     \setmathfont{TeX Gyre Pagella Math}
%   },
%   hooks/chaphead = \sffamily,
% }
% \end{verbatim}
% \end{function}
%
% \subsection{Usage Examples}
%
% Using a built-in theme:
% \begin{verbatim}
% \documentclass{nus-thesis}
% \ThesisSetup{
%   font = palatino,
%   title = My Thesis,
%   author = John Doe,
% }
% \end{verbatim}
%
% Using a custom theme (XeTeX/LuaTeX):
% \begin{verbatim}
% \ThesisDefineFontTheme{research}{
%   main-font = {STIX Two Text},
%   math-font = {STIX Two Math},
%   heading-style = sans,
% }
% \ThesisSetup{font = research}
% \end{verbatim}
%
% For detailed information about math fonts and advanced configuration, see
% |FONT_THEME_IMPLEMENTATION.md| and |MATH_FONT_SYSTEM.md| in the package distribution.
%
% \section{Optional Features}
%
% \subsection{Glossaries and Acronyms}
%
% \begin{function}{glossaries}
%   \begin{syntax}
%     |glossaries| = \meta{true,false}
%   \end{syntax}
% Controls whether the |glossaries-extra| package is loaded for managing glossaries and acronyms.
%
% When set to |false| (the default), glossaries support is not loaded. This avoids warnings
% about missing |\printglossary| commands when you don't need glossaries functionality.
%
% When set to |true|, the |glossaries-extra| package is loaded with support for abbreviations,
% enabling commands like |\newacronym|, |\gls|, and |\printglossary|.
%
% Example without glossaries (default):
% \begin{verbatim}
% \documentclass{nus-thesis}
% \ThesisSetup{
%   title = My Thesis,
%   author = John Doe,
% }
% \end{verbatim}
%
% Example with glossaries enabled:
% \begin{verbatim}
% \documentclass{nus-thesis}
% \ThesisSetup{
%   glossaries = true,
%   title = My Thesis,
%   author = John Doe,
% }
% \begin{document}
% \newacronym{api}{API}{Application Programming Interface}
% First use: \gls{api}. Second use: \gls{api}.
% \printglossary[type=abbreviations]
% \end{document}
% \end{verbatim}
% \end{function}
%
% \section{Front Matter Environments}
%
% \subsection{Declaration Page}
%
% NUS requires all theses to include a signed declaration of originality.
% The class provides a composable environment that supports the required
% originality statement, an optional generative-AI disclosure, and a
% signature block.
%
% \begin{environment}{declaration}
%   \begin{syntax}
%     |\begin{declaration}|
%     \quad|\DeclarationStatement|
%     \quad|\DeclarationGenAI| \oarg{template}
%     \quad|\DeclarationSignature| \oarg{image}
%     |\end{declaration}|
%   \end{syntax}
% Opens a self-contained declaration page (plain page style, no running
% header). The page is cleared before the environment begins and a
% |\cleardoublepage| is issued at the end so that the following front-matter
% content always starts on a recto page.
%
% The body is built up from three sub-commands described below.
% A typical usage for a thesis where the student used AI tools is:
% \begin{verbatim}
% \begin{declaration}
%   \DeclarationStatement
%   \DeclarationGenAI           % template B: AI used
%   \DeclarationSignature       % unsigned; add [sig.png] for image
% \end{declaration}
% \end{verbatim}
% \end{environment}
%
% \begin{function}{\DeclarationStatement}
%   \begin{syntax}
%     |\DeclarationStatement|
%   \end{syntax}
% Typesets the mandatory NUS originality statement:
% \textit{``I hereby declare that this \meta{document-type} is my original
% work and has been written by me in its entirety.  I have duly acknowledged
% all the sources of information which have been used in this
% \meta{document-type}. This \meta{document-type} has also not been
% submitted for any degree in any university previously.''}
%
% The word \meta{document-type} is taken from the |document-type| key (default
% |thesis|); it tracks the value set in |\ThesisSetup|.
% This command must appear inside a |declaration| environment.
% \end{function}
%
% \begin{function}{\DeclarationGenAI}
%   \begin{syntax}
%     |\DeclarationGenAI|
%     |\DeclarationGenAI| \oarg{none}
%   \end{syntax}
% Typesets a \textbf{Use of Generative AI} disclosure paragraph.
% Two templates are available, selected via the optional argument:
%
% \begin{description}
%   \item[Template B (default, no argument)] Use when generative AI tools
%     \emph{were} used, solely for language refinement, structuring, and
%     proofreading. Produces the text: \textit{``I acknowledge the use of
%     generative artificial intelligence (AI) tools in the preparation of
%     this \meta{document-type}, solely for language refinement, structuring
%     and proofreading purposes. All AI-generated outputs have been
%     critically reviewed, edited, and verified by me. I confirm that the
%     intellectual content, analysis, and conclusions presented are entirely
%     my own, and I take full responsibility for the work submitted.''}
%
%   \item[Template A (\texttt{[none]})] Use when \emph{no} generative AI tools
%     were used. Produces the text: \textit{``I declare that no generative
%     artificial intelligence (AI) tools were used in the preparation of the
%     \meta{document-type}.''}
% \end{description}
%
% \begin{verbatim}
% \DeclarationGenAI         % template B: AI used for language/proofreading
% \DeclarationGenAI[none]   % template A: no AI used
% \end{verbatim}
%
% For situations not covered by either template, use
% |\DeclarationGenAICustom| instead.
% \end{function}
%
% \begin{function}{\DeclarationGenAICustom}
%   \begin{syntax}
%     |\DeclarationGenAICustom| \marg{text}
%   \end{syntax}
% Typesets a \textbf{Use of Generative AI} heading followed by the
% arbitrary \meta{text} supplied by the user. Use this command when the
% built-in templates in |\DeclarationGenAI| do not match the disclosure
% required by your programme or supervisor.
%
% \begin{verbatim}
% \DeclarationGenAICustom{%
%   I used large-language-model tools to generate initial outlines for
%   Chapters~3 and~5, which I subsequently rewrote in their entirety.
% }
% \end{verbatim}
% \end{function}
%
% \begin{function}{\DeclarationSignature}
%   \begin{syntax}
%     |\DeclarationSignature|
%     |\DeclarationSignature| \oarg{image}
%   \end{syntax}
% Typesets a centred signature block consisting of two ruled lines labelled
% with the author name and the submission date, respectively. When the
% optional \meta{image} path is supplied, the referenced image is placed
% above the signature line (useful for electronic submissions that carry a
% scanned or digital signature).
%
% \begin{verbatim}
% \DeclarationSignature                    % unsigned block
% \DeclarationSignature[./signature.png]   % with signature image
% \end{verbatim}
% \end{function}
%
% \begin{function}{\DeclarationPage}
%   \begin{syntax}
%     |\DeclarationPage|
%     |\DeclarationPage| \oarg{image}
%   \end{syntax}
% A backward-compatible shorthand that emits a |declaration| environment
% containing only |\DeclarationStatement| and |\DeclarationSignature|
% (no AI disclosure). New documents should prefer the full environment so
% that the AI disclosure can be included.
%
% \begin{verbatim}
% \DeclarationPage                       % no signature image
% \DeclarationPage[./signature.png]      % with signature image
% \end{verbatim}
% \end{function}
%
% \subsection{Abstract}
%
% \begin{environment}{abstract}
%   \begin{syntax}
%     |\begin{abstract}| \oarg{prefix}
%     \meta{abstract text}
%     |\end{abstract}|
%   \end{syntax}
% Typesets an abstract as an unnumbered chapter and adds it to the table of contents.
% The optional \meta{prefix} argument prepends a word to the chapter title. Without a
% prefix, the chapter is titled ``Abstract''. With a prefix, for example |[Lay]|, the
% chapter is titled ``Lay Abstract''.
%
% Some degree programmes require both a technical abstract and a lay abstract
% (a plain-language summary for a general audience). Both can be included in the
% front matter:
% \begin{verbatim}
% \begin{abstract}
%   This thesis investigates \dots
% \end{abstract}
%
% \begin{abstract}[Lay]
%   In plain language, this thesis is about \dots
% \end{abstract}
% \end{verbatim}
% \end{environment}
%
% \StopEventually{}  % No index in user manual - it's a short guide
%
% \section{Implementation}
%
% This section documents the internal implementation of the nus-thesis class.
% It is intended for developers and maintainers.
%
%    \begin{macrocode}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Font Theme Definitions
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Define built-in font themes using the new theme system
% Each theme specifies engine-specific font loading and hook customization

% Computer Modern theme: Classic TeX typography (Knuth's original design)
% Uses CM (pdfTeX) or Latin Modern (XeTeX/LuaTeX)
\DeclareThesisFontTheme{computermodern}{
  pdftex = {
    % Computer Modern is the default - no packages needed
    % Optionally load Latin Modern for better quality
    \RequirePackage{lmodern}
  },
  fontspec = {
    \RequirePackage{unicode-math}
    \setmainfont{Latin~Modern~Roman}[Ligatures=TeX]
    \setsansfont{Latin~Modern~Sans}[Scale=MatchLowercase]
    \setmonofont{Latin~Modern~Mono}[Scale=MatchLowercase]
    \setmathfont{Latin~Modern~Math}
  },
  % All hooks use defaults (serif body, serif headings)
}

% Times theme: Classic serif font (Times Roman)
% Uses defaults for all hooks (serif throughout)
\DeclareThesisFontTheme{times}{
  pdftex = {
    \RequirePackage{mathptmx}  % Times + math support
  },
  fontspec = {
    \RequirePackage{unicode-math}
    \setmainfont{TeX~Gyre~Termes}[Ligatures=TeX]
    \setsansfont{TeX~Gyre~Heros}[Scale=0.95]
    \setmonofont{Latin~Modern~Mono}[Scale=MatchLowercase]
    \setmathfont{TeX~Gyre~Termes~Math}
  },
  % All hooks use defaults (serif body, serif headings)
}

% Helvetica theme: Sans-serif throughout
% Clean, modern look with sans fonts for everything
\DeclareThesisFontTheme{helvetica}{
  pdftex = {
    \RequirePackage[scaled=0.95]{helvet}
    \renewcommand{\familydefault}{\sfdefault}
    \RequirePackage{mathastext}
    \RequirePackage{arevmath}
    \RequirePackage[mono,varl]{inconsolata}
  },
  fontspec = {
    \RequirePackage{unicode-math}
    \setsansfont{TeX~Gyre~Heros}[Scale=0.95]
    \setmainfont{TeX~Gyre~Heros}[Scale=0.95]
    \setmonofont{Inconsolata}[Scale=MatchLowercase]
    \setmathfont{Fira~Math}  % Sans-serif math font
  },
  hooks/body = \sffamily,
  hooks/titlepage = \sffamily,
  hooks/chaphead = \sffamily,
  hooks/heading = \sffamily,
  hooks/caption = \sffamily,
}

% Palatino theme: Serif body with sans-serif headings
% Professional combination of Palatino and Helvetica
\DeclareThesisFontTheme{palatino}{
  pdftex = {
    \RequirePackage[sc]{mathpazo}  % Palatino + smallcaps
    \RequirePackage[scaled=0.95]{helvet}
    \RequirePackage[varl]{inconsolata}
  },
  fontspec = {
    \RequirePackage{unicode-math}
    \setmainfont{TeX~Gyre~Pagella}[Ligatures=TeX]
    \setsansfont{TeX~Gyre~Heros}[Scale=0.95]
    \setmonofont{Inconsolata}[Scale=MatchLowercase]
    \setmathfont{TeX~Gyre~Pagella~Math}
  },
  hooks/chaphead = \sffamily,
  hooks/heading = \sffamily,
  hooks/caption = \sffamily,
}

% Libertine theme: Linux Libertine with multi-engine support
% Elegant serif font with excellent unicode coverage
\DeclareThesisFontTheme{libertine}{
  pdftex = {
    \RequirePackage[scaled=0.9,varl]{inconsolata}
    \RequirePackage[mono=false,sb]{libertinus}
    \RequirePackage{libertinust1math}
  },
  fontspec = {
    \RequirePackage{unicode-math}
    \RequirePackage{libertinus}
    \setmonofont[Scale=MatchUppercase]{Inconsolata}
    \setmathfont{Libertinus~Math}
  },
  hooks/chaphead = \sffamily,
  hooks/heading = \sffamily,
  hooks/caption = \sffamily,
}

% Noto theme: Google Noto fonts
% Modern, comprehensive font family with excellent language support
\DeclareThesisFontTheme{noto}{
  pdftex = {
    \RequirePackage{notomath}
    \RequirePackage{inconsolata}
  },
  fontspec = {
    \RequirePackage{unicode-math}
    \setmainfont{Noto~Serif}
    \setsansfont{Noto~Sans}
    \setmonofont{Noto~Sans~Mono}[Scale=MatchLowercase]
    \setmathfont{STIXTwoMath-Regular.otf}  % Noto doesn't have a math font yet
  },
  hooks/titlepage = \sffamily,
  hooks/chaphead = \sffamily,
  hooks/heading = \sffamily,
  hooks/caption = \sffamily,
}

% Minion Pro theme: Adobe professional fonts
% Premium serif/sans combination (requires commercial fonts)
\DeclareThesisFontTheme{minionpro}{
  pdftex = {
    \RequirePackage[lf,minionint,loosequotes,footnotefigures]{MinionPro}
    \microtypesetup{kerning=false,expansion=false}
    \RequirePackage[lf]{MyriadPro}
    \RequirePackage[scaled=0.9,varl]{inconsolata}
  },
  fontspec = {
    \RequirePackage{unicode-math}
    \setmainfont{Minion~Pro}
    \setsansfont{Myriad~Pro}
    \setmonofont{Inconsolata}[Scale=0.9]
    \setmathfont{TeX~Gyre~Pagella~Math}  % Minion Math is commercial
  },
  %hooks/titlepage = \sffamily,
  hooks/chaphead = \sffamily,
  hooks/heading = \sffamily,
  hooks/caption = \sffamily,
}

\ProcessKeysOptions { nus-thesis }


\NewDocumentCommand \ThesisSetup { m } {
  \keys_set:nn { nus-thesis } { #1 }
}

